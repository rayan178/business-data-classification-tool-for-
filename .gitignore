import math
import pandas as pd
from openai import OpenAI
import time

from openpyxl.reader.excel import load_workbook

# -----------------------------
# Setup OpenAI Client
# -----------------------------
client = OpenAI(api_key=" ")  # uses your saved API key

# -----------------------------
# Load Workbook
# -----------------------------
file_path = "Testing.xlsx"
wb = load_workbook(file_path)
ws = wb.active

# Ensure Column D header exists
if ws.cell(row=1, column=4).value is None:
    ws.cell(row=1, column=5).value = "CATEGORY"
    wb.save(file_path)

# -----------------------------
# Process Rows (START FROM ROW 2)
# -----------------------------
for row in range(2, ws.max_row + 1):

    item_name = ws.cell(row=row, column=2).value  # Column B
    category_cell = ws.cell(row=row, column=4)    # Column D

    if not item_name:
        continue

    # Skip if already filled
    if category_cell.value not in (None, ""):
        continue

    try:
        response = client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[
                {
                    "role": "system",
                    "content": (
                        "You are a STRICT product classifier.\n"
                        "1) COOKING PRODUCTS, BREADS, SAUCES, CHOCOLATE SPREADS, JAMS, CEREALS AND EXCLUDING DRINKS → GROCERY\n"
                        "2) DRINKS LIKE JUICES, WATER, FIZZY → DRINKS\n"
                        "3) CLEANING PRODUCTS FOR HOMES, ROOM SPRAY → HOUSEHOLD \n"
                        "4) CANDY'S SWEETS, CHOCOLATE BARS, -> CONFECTIONERY"
                        "5) everything else → OTHER\n"
                        "Return ONLY one word."
                    )
                },
                {"role": "user", "content": str(item_name)}
            ],
            temperature=0
        )

        category = response.choices[0].message.content.strip()

        # Write immediately to Excel
        category_cell.value = category
        wb.save(file_path)  # ← saves after each row

        print(f"Row {row} → {item_name} → {category}")

        time.sleep(0.4)

    except Exception as e:
        print(f"Error at row {row}: {e}")
        category_cell.value = "ERROR"
        wb.save(file_path)

print("✅ Done. Updated same Excel file line by line.")
